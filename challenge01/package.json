{
  "name": "remi-message-ingestor",
  "version": "1.0.0",
  "description": "Standalone REMI SMS/MMS group message ingestor for the Aye Aye Vacations engineering challenge.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "db:push": "prisma db push",
    "prisma:generate": "prisma generate",
    "typecheck:fresh": "prisma generate && tsc --noEmit",
    "simulate": "tsx scripts/simulate.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.10.1",
    "express": "^5.1.0",
    "zod": "^3.25.64"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.1",
    "prisma": "^6.10.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
